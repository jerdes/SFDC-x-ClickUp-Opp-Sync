# ============================================================
# SFDC x ClickUp Opportunity Sync — Environment Configuration
# Copy this file to .env and fill in all values before running.
# ============================================================


# ----------------------------------------------------------------
# GMAIL (IMAP + App Password — no Google Cloud Console needed)
# Setup: Gmail Settings → Forwarding and POP/IMAP → Enable IMAP
# App password: myaccount.google.com → Security → App passwords
# ----------------------------------------------------------------

# Your Gmail address
GMAIL_ADDRESS=you@gmail.com

# 16-character Google App Password (spaces optional — they will be stripped)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# IMAP server (leave as default for Gmail; change for Google Workspace custom domains)
GMAIL_IMAP_HOST=imap.gmail.com

# Substring of the email subject to search for (must match the SF report email)
GMAIL_SUBJECT_PATTERN=Salesforce Opportunity

# Suffix or glob pattern for the CSV attachment filename
GMAIL_ATTACHMENT_NAME_PATTERN=.csv


# ----------------------------------------------------------------
# CLICKUP
# ----------------------------------------------------------------

# Your ClickUp personal API token (Settings → Apps → API Token)
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional alternative token name for staging environments
CLICKUP_STAGING_API_KEY=

# The ID of the ClickUp list where opportunities will be managed
# Find it in the URL: app.clickup.com/WORKSPACE/v/li/LIST_ID
CLICKUP_LIST_ID=123456789

# ClickUp API base URL (host-only or /api/v2 both supported)
CLICKUP_BASE_URL=https://api.clickup.com/api/v2

# Comma-separated stage values that trigger a task to be closed
CLICKUP_CLOSED_STAGES=Closed Won,Closed Lost


# ----------------------------------------------------------------
# CLICKUP CUSTOM FIELD IDs
# Run: curl -H "Authorization: YOUR_TOKEN" https://api.clickup.com/api/v2/list/LIST_ID/field
# to discover the UUID for each field.
# Create any fields that don't exist yet in your ClickUp list first.
# ----------------------------------------------------------------

# REQUIRED: Salesforce Opportunity ID (Text field — used as the matching key)
CLICKUP_FIELD_ID_SF_OPPORTUNITY_ID=

# Opportunity Owner
CLICKUP_FIELD_ID_OWNER=

# Account Name
CLICKUP_FIELD_ID_ACCOUNT_NAME=

# Stage (Dropdown field recommended)
CLICKUP_FIELD_ID_STAGE=

# Annual Recurring Revenue (ARR) (Number or Currency field)
CLICKUP_FIELD_ID_ARR=

# Sales Estimated Quota Relief (Number or Currency field)
CLICKUP_FIELD_ID_SALES_ESTIMATED_QUOTA_RELIEF=

# Close Date (Date field)
CLICKUP_FIELD_ID_CLOSE_DATE=

# Next Step Date (Date field)
CLICKUP_FIELD_ID_NEXT_STEP_DATE=

# Next Step (Text field)
CLICKUP_FIELD_ID_NEXT_STEP=

# Forecast Category (Dropdown or Text field)
CLICKUP_FIELD_ID_FORECAST_CATEGORY=

# Type (Text field)
CLICKUP_FIELD_ID_TYPE=

# MEDDPICC — Metrics
CLICKUP_FIELD_ID_METRICS=

# MEDDPICC — Economic Buyer
CLICKUP_FIELD_ID_ECONOMIC_BUYER=

# MEDDPICC — Decision Criteria
CLICKUP_FIELD_ID_DECISION_CRITERIA=

# MEDDPICC — Decision Process
CLICKUP_FIELD_ID_DECISION_PROCESS=

# MEDDPICC — Paper Process
CLICKUP_FIELD_ID_PAPER_PROCESS=

# MEDDPICC — Implicated Pain
CLICKUP_FIELD_ID_IMPLICATED_PAIN=

# Champion Name
CLICKUP_FIELD_ID_CHAMPION_NAME=

# Competitor
CLICKUP_FIELD_ID_COMPETITOR=

# Other Competitor
CLICKUP_FIELD_ID_OTHER_COMPETITOR=

# CUO Meeting (Checkbox field)
CLICKUP_FIELD_ID_CUO_MEETING=

# Completed (Checkbox field)
CLICKUP_FIELD_ID_COMPLETED=

# Evaluation Agreed (Checkbox field)
CLICKUP_FIELD_ID_EVALUATION_AGREED=

# Pricing Discussed (Checkbox field)
CLICKUP_FIELD_ID_PRICING_DISCUSSED=

# Decision Criteria Met (Checkbox field)
CLICKUP_FIELD_ID_DECISION_CRITERIA_MET=

# Economic Buyer Approved (Checkbox field)
CLICKUP_FIELD_ID_ECONOMIC_BUYER_APPROVED=

# Department
CLICKUP_FIELD_ID_DEPARTMENT=

# Ironclad Signatory
CLICKUP_FIELD_ID_IRONCLAD_SIGNATORY=

# Mutual Action Plan (MAP) URL (URL field)
CLICKUP_FIELD_ID_MAP_URL=

# 3 Whys Business Case
CLICKUP_FIELD_ID_THREE_WHYS=

# Plan
CLICKUP_FIELD_ID_PLAN=

# Number of Plan Seats (Number field)
CLICKUP_FIELD_ID_NUMBER_OF_PLAN_SEATS=

# Created Date (Date field)
CLICKUP_FIELD_ID_CREATED_DATE=


# ----------------------------------------------------------------
# CSV FIELD MAPPING
# These are the exact column headers in your Salesforce CSV export.
# Only change these if your report uses different column names.
# ----------------------------------------------------------------

CSV_MAP_SF_OPPORTUNITY_ID=Opportunity ID
CSV_MAP_NAME=Opportunity Name
CSV_MAP_OWNER=Opportunity Owner
CSV_MAP_ACCOUNT_NAME=Account Name
CSV_MAP_STAGE=Stage
CSV_MAP_ARR=Annual Recurring Revenue (ARR)
CSV_MAP_SALES_ESTIMATED_QUOTA_RELIEF=Sales Estimated Quota Relief
CSV_MAP_CLOSE_DATE=Close Date
CSV_MAP_NEXT_STEP_DATE=Next Step Date
CSV_MAP_NEXT_STEP=Next Step
CSV_MAP_FORECAST_CATEGORY=Forecast Category
CSV_MAP_TYPE=Type
CSV_MAP_METRICS=Metrics
CSV_MAP_ECONOMIC_BUYER=Economic Buyer
CSV_MAP_DECISION_CRITERIA=Decision Criteria
CSV_MAP_DECISION_PROCESS=Decision Process
CSV_MAP_PAPER_PROCESS=Paper Process
CSV_MAP_IMPLICATED_PAIN=Implicated Pain
CSV_MAP_CHAMPION_NAME=Champion Name
CSV_MAP_COMPETITOR=Competitor
CSV_MAP_OTHER_COMPETITOR=Other Competitor
CSV_MAP_CUO_MEETING=CUO Meeting
CSV_MAP_COMPLETED=Completed
CSV_MAP_EVALUATION_AGREED=Evaluation Agreed
CSV_MAP_PRICING_DISCUSSED=Pricing Discussed
CSV_MAP_DECISION_CRITERIA_MET=Decision Criteria Met
CSV_MAP_ECONOMIC_BUYER_APPROVED=Economic Buyer Approved
CSV_MAP_DEPARTMENT=Department
CSV_MAP_IRONCLAD_SIGNATORY=Ironclad Signatory
CSV_MAP_MAP_URL=Mutual Action Plan (MAP) URL
CSV_MAP_THREE_WHYS=3 Whys Business Case
CSV_MAP_PLAN=Plan
CSV_MAP_NUMBER_OF_PLAN_SEATS=Number of Plan Seats
CSV_MAP_CREATED_DATE=Created Date


# ----------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------

LOG_FILE=logs/sync.log
LOG_LEVEL=INFO
